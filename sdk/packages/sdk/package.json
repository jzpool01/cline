{
	"name": "@tarogo/sdk",
	"description": "Tarogo SDK - @tarogo/core 的用户面向别名",
	"version": "0.0.42",
	"repository": {
		"type": "git",
		"url": "https://github.com/tarogo/tcode",
		"directory": "sdk/packages/sdk"
	},
	"type": "module",
	"types": "./dist/index.d.ts",
	"main": "./dist/index.js",
	"private": false,
	"publishConfig": {
		"access": "public"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "bun run bun.mts && bun tsc -p tsconfig.build.json",
		"typecheck": "bun tsc -p tsconfig.json --noEmit"
	},
	"dependencies": {
		"@tarogo/core": "workspace:*"
	},
	"engines": {
		"node": ">=22"
	},
	"files": [
		"dist"
	],
	"license": "Apache-2.0"
}
