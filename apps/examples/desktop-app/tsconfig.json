{
	"compilerOptions": {
		"lib": ["dom", "dom.iterable", "esnext"],
		"allowJs": true,
		"target": "ES6",
		"skipLibCheck": true,
		"strict": true,
		"noEmit": true,
		"esModuleInterop": true,
		"module": "esnext",
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"isolatedModules": true,
		"jsx": "react-jsx",
		"incremental": true,
		"plugins": [
			{
				"name": "next"
			}
		],
		"paths": {
			"@/*": ["./*"],
			"@tarogo/agents": ["../../../sdk/packages/agents/src/index.ts"],
			"@tarogo/core": ["../../../sdk/packages/core/src/index.ts"],
			"@tarogo/core/hub": ["../../../sdk/packages/core/src/hub/index.ts"],
			"@tarogo/llms": ["../../../sdk/packages/llms/src/index.ts"],
			"@tarogo/shared": ["../../../sdk/packages/shared/src/index.ts"],
			"@tarogo/shared/storage": [
				"../../../sdk/packages/shared/src/storage/index.ts"
			],
			"@tarogo/shared/db": ["../../../sdk/packages/shared/src/db/index.ts"],
			"@tarogo/shared/*": [
				"../../../sdk/packages/shared/src/*",
				"../../../sdk/packages/shared/src/*/index.ts"
			]
		}
	},
	"include": [
		"**/*.ts",
		"**/*.tsx",
		".next/types/**/*.ts",
		".next/dev/types/**/*.ts"
	],
	"exclude": ["node_modules"]
}
