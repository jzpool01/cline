{
	"extends": "../../../sdk/packages/tsconfig.base.json",
	"compilerOptions": {
		"outDir": "dist",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"target": "ESNext",
		"paths": {
			"@tarogo/agents": ["../../../sdk/packages/agents/src/index.ts"],
			"@tarogo/agents/*": [
				"../../../sdk/packages/agents/src/*",
				"../../../sdk/packages/agents/src/*/index.ts"
			],
			"@tarogo/core": ["../../../sdk/packages/core/src/index.ts"],
			"@tarogo/core/hub/daemon-entry": [
				"../../../sdk/packages/core/src/hub/daemon/entry.ts"
			],
			"@tarogo/core/*": [
				"../../../sdk/packages/core/src/*",
				"../../../sdk/packages/core/src/*/index.ts"
			],
			"@tarogo/llms": ["../../../sdk/packages/llms/src/index.ts"],
			"@tarogo/shared": ["../../../sdk/packages/shared/src/index.ts"],
			"@tarogo/shared/storage": [
				"../../../sdk/packages/shared/src/storage/index.ts"
			],
			"@tarogo/shared/db": ["../../../sdk/packages/shared/src/db/index.ts"],
			"@tarogo/shared/*": [
				"../../../sdk/packages/shared/src/*",
				"../../../sdk/packages/shared/src/*/index.ts"
			]
		}
	},
	"include": ["sidecar/**/*.ts"]
}
