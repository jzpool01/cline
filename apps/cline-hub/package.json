{
	"name": "@tarogo/hub",
	"version": "0.0.0",
	"private": true,
	"description": "Tarogo Hub 浏览器仪表盘：实时客户端、会话、流式聊天和 Hub 重启。",
	"type": "module",
	"exports": {
		".": "./src/server.ts"
	},
	"scripts": {
		"build:webview": "bun run --cwd src/webview build",
		"dev": "bun run src/dev.ts",
		"start": "bun run src/server.ts",
		"smoke:options": "bun run src/validate-options.ts",
		"typecheck": "bun tsc -p tsconfig.json --noEmit"
	},
	"dependencies": {
		"@tarogo/core": "workspace:*",
		"@tarogo/llms": "workspace:*",
		"@tarogo/shared": "workspace:*"
	}
}
